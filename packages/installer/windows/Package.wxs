<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package
    Name="ShoMetrics Helper"
    Manufacturer="ShoMetrics"
    Version="$(var.ProductVersion)"
    UpgradeCode="ec14c0fe-f992-4a8d-bfbc-b76c8592993f"
    Scope="perMachine">

    <!-- Local and CI smoke builds may rebuild the same ProductVersion many times.
         Treat same-version packages as upgrades so service registration stays single. -->
    <MajorUpgrade
      AllowSameVersionUpgrades="yes"
      DowngradeErrorMessage="A newer version of ShoMetrics Helper is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="ShoMetricsProgramFilesFolder" Name="ShoMetrics">
        <Directory Id="InstallFolder" Name="ShoMetrics Helper">
          <Directory Id="ServiceFolder" Name="Service" />
          <Directory Id="ControlPanelFolder" Name="Control Panel" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Directory Id="ProgramMenuShoMetricsFolder" Name="ShoMetrics" />
    </StandardDirectory>

    <StandardDirectory Id="CommonAppDataFolder">
      <Directory Id="ProgramDataShoMetricsFolder" Name="ShoMetrics">
        <Directory Id="ProgramDataSourceWindowsFolder" Name="Source.Windows">
          <Directory Id="LogFolder" Name="logs" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <DirectoryRef Id="ServiceFolder">
      <Component Id="WindowsServiceComponent" Guid="5d259df7-189e-4ae7-b7dd-fdb7995b9fc0" Bitness="always64">
        <File
          Id="WindowsServiceExe"
          Source="$(var.InstallerPayloadDir)\service\ShoMetrics.Source.Windows.Service.exe"
          KeyPath="yes" />
        <ServiceInstall
          Id="WindowsServiceInstall"
          Type="ownProcess"
          Name="ShoMetrics Source Windows"
          DisplayName="ShoMetrics Helper"
          Description="Provides Windows hardware sensor data to ShoMetrics."
          Start="auto"
          Account="LocalSystem"
          ErrorControl="normal" />
        <ServiceControl
          Id="WindowsServiceControl"
          Name="ShoMetrics Source Windows"
          Start="install"
          Stop="both"
          Remove="uninstall"
          Wait="yes" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="ControlPanelFolder">
      <Component Id="ControlPanelComponent" Guid="f81ffb02-97d0-4b07-810c-3778b64d8818" Bitness="always64">
        <File
          Id="ControlPanelExe"
          Source="$(var.InstallerPayloadDir)\control-panel\ShoMetrics.Source.Windows.ControlPanel.exe"
          KeyPath="yes">
          <Shortcut
            Id="ControlPanelStartMenuShortcut"
            Directory="ProgramMenuShoMetricsFolder"
            Name="ShoMetrics Helper"
            Description="Open ShoMetrics Helper status and diagnostics."
            Advertise="yes"
            WorkingDirectory="ControlPanelFolder" />
        </File>
        <RemoveFolder Id="RemoveProgramMenuShoMetricsFolder" Directory="ProgramMenuShoMetricsFolder" On="uninstall" />
      </Component>
    </DirectoryRef>

    <DirectoryRef Id="LogFolder">
      <Component Id="LogDirectoryComponent" Guid="9faea618-b08e-4d29-bd94-88cd55021886" Bitness="always64">
        <CreateFolder />
        <RegistryValue
          Root="HKLM"
          Key="Software\ShoMetrics\ShoMetrics Helper"
          Name="LogDirectory"
          Type="integer"
          Value="1"
          KeyPath="yes" />
      </Component>
    </DirectoryRef>

    <Feature Id="ProductFeature" Title="ShoMetrics Helper" Level="1">
      <ComponentRef Id="WindowsServiceComponent" />
      <ComponentRef Id="ControlPanelComponent" />
      <ComponentRef Id="LogDirectoryComponent" />
      <Files Directory="ServiceFolder" Include="$(var.InstallerPayloadDir)\service\**">
        <Exclude Files="$(var.InstallerPayloadDir)\service\ShoMetrics.Source.Windows.Service.exe" />
      </Files>
      <Files Directory="ControlPanelFolder" Include="$(var.InstallerPayloadDir)\control-panel\**">
        <Exclude Files="$(var.InstallerPayloadDir)\control-panel\ShoMetrics.Source.Windows.ControlPanel.exe" />
      </Files>
    </Feature>
  </Package>
</Wix>
