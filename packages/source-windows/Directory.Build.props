<Project>
  <Import Project="..\..\build\version.props" Condition="Exists('..\..\build\version.props')" />

  <PropertyGroup>
    <Version Condition="'$(Version)' == ''">$(ShoMetricsVersion)</Version>
    <PackageVersion Condition="'$(PackageVersion)' == ''">$(ShoMetricsVersion)</PackageVersion>
    <InformationalVersion Condition="'$(InformationalVersion)' == ''">$(ShoMetricsVersion)</InformationalVersion>
    <IncludeSourceRevisionInInformationalVersion>false</IncludeSourceRevisionInInformationalVersion>
    <AssemblyVersion Condition="'$(AssemblyVersion)' == ''">$(ShoMetricsAssemblyVersion)</AssemblyVersion>
    <FileVersion Condition="'$(FileVersion)' == ''">$(ShoMetricsAssemblyVersion)</FileVersion>
    <RestorePackagesWithLockFile>true</RestorePackagesWithLockFile>
    <RestoreLockedMode Condition="'$(UpdatePackageLocks)' != 'true'">true</RestoreLockedMode>
    <!-- Default packages.lock.json is the dev graph. Publish sets this to keep RID locks separate. -->
    <NuGetLockFilePath Condition="'$(SourceWindowsPackageLockFlavor)' != ''">$(MSBuildProjectDirectory)\packages.$(SourceWindowsPackageLockFlavor).lock.json</NuGetLockFilePath>
    <NuGetAudit>true</NuGetAudit>
    <NuGetAuditMode>all</NuGetAuditMode>
  </PropertyGroup>
</Project>
