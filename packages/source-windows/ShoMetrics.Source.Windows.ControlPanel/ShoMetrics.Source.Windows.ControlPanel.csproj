<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <AssemblyName>ShoMetricsHelper</AssemblyName>
    <PackageId>ShoMetrics.Source.Windows.ControlPanel</PackageId>
    <AssemblyTitle>ShoMetrics Helper</AssemblyTitle>
    <FileDescription>ShoMetrics Helper</FileDescription>
    <Product>ShoMetrics Helper</Product>
    <Company>ShoMetrics</Company>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.19041.0</TargetPlatformMinVersion>
    <RuntimeIdentifier>win-x64</RuntimeIdentifier>
    <UseWinUI>true</UseWinUI>
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\ShoMetrics.Source.Windows.Contracts\ShoMetrics.Source.Windows.Contracts.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\sho-metrics-icon-titlebar-light.svg"
             CopyToOutputDirectory="PreserveNewest" />
    <Content Include="..\..\hub\com.ez.sho-metrics.sdPlugin\imgs\actions\sho-metrics\icon.svg"
             Link="Assets\sho-metrics-icon.svg"
             CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Grpc.Net.Client" Version="[2.71.0]" />
    <!-- Override Grpc.Net.Client's old minimum dependency, which fails the repo's NuGet signature trust policy. -->
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" Version="[10.0.8]" />
    <PackageReference Include="Microsoft.WindowsAppSDK.WinUI" Version="[2.1.0]" />
    <!-- Framework-dependent Windows App SDK publishes require the Runtime package explicitly when using component packages. -->
    <PackageReference Include="Microsoft.WindowsAppSDK.Runtime" Version="[2.1.3]" />
  </ItemGroup>

</Project>
