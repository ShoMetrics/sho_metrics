<Window x:Class="ShoMetrics.Source.Windows.ControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:media="using:Microsoft.UI.Xaml.Media.Imaging"
        xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
        xmlns:toolkit="using:ShoMetrics.Source.Windows.ControlPanel.Controls"
        Title="ShoMetrics Helper">
    <Grid x:Name="RootGrid"
          Background="{ThemeResource ControlPanelPageBackgroundBrush}">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <media:BitmapImage x:Key="TitleBarLogoSource"
                                           UriSource="ms-appx:///Assets/sho-metrics-icon-titlebar-light.png" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <media:BitmapImage x:Key="TitleBarLogoSource"
                                           UriSource="ms-appx:///Assets/sho-metrics-icon-titlebar-dark.png" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="HighContrast">
                        <media:BitmapImage x:Key="TitleBarLogoSource"
                                           UriSource="ms-appx:///Assets/sho-metrics-icon-titlebar-dark.png" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Background="{ThemeResource ControlPanelPageBackgroundBrush}">
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <Image Source="{ThemeResource TitleBarLogoSource}"
                       Width="18"
                       Height="18"
                       VerticalAlignment="Center" />
                <TextBlock Text="ShoMetrics Helper"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           FontSize="14"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <muxc:NavigationView x:Name="Navigation"
                             Grid.Row="1"
                             PaneDisplayMode="Left"
                             CompactPaneLength="48"
                             OpenPaneLength="180"
                             IsPaneToggleButtonVisible="False"
                             IsPaneOpen="True"
                             Background="{ThemeResource ControlPanelPageBackgroundBrush}"
                             IsSettingsVisible="False"
                             IsBackButtonVisible="Collapsed"
                             SelectionChanged="OnNavigationSelectionChanged">
            <muxc:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
            </muxc:NavigationView.Resources>
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Home"
                                         IsSelected="True"
                                         Icon="Home"
                                         Tag="status" />
                <muxc:NavigationViewItem Content="About"
                                         Icon="Help"
                                         Tag="about" />
            </muxc:NavigationView.MenuItems>

            <Grid>
                <ScrollViewer x:Name="StatusPage"
                              Padding="40,32,40,32"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">
                        <StackPanel Spacing="6">
                            <TextBlock Text="ShoMetrics status"
                                       Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="Check ShoMetrics Helper, driver access, and sensor diagnostics."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="App status"
                                       Style="{ThemeResource SubtitleTextBlockStyle}" />
                            <StackPanel Spacing="4">
                                <toolkit:SettingsExpander x:Name="ServiceDetailsExpander"
                                                          Header="ShoMetrics Helper"
                                                          IsExpanded="False">
                                    <toolkit:SettingsExpander.HeaderIcon>
                                        <FontIcon x:Name="ServiceTileStatusIcon"
                                                  AutomationProperties.AccessibilityView="Raw"
                                                  FontSize="18" />
                                    </toolkit:SettingsExpander.HeaderIcon>
                                    <toolkit:SettingsExpander.Description>
                                        <StackPanel Spacing="4">
                                            <TextBlock x:Name="ServiceTileDetailText"
                                                       TextWrapping="Wrap" />
                                            <TextBlock x:Name="ServiceTileRecoveryText"
                                                       Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                                       TextWrapping="Wrap"
                                                       Visibility="Collapsed" />
                                        </StackPanel>
                                    </toolkit:SettingsExpander.Description>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="12"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="ServiceTileStatusText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   VerticalAlignment="Center" />
                                        <Button x:Name="ServicePrimaryActionButton"
                                                AutomationProperties.AutomationId="ServicePrimaryActionButton"
                                                Visibility="Collapsed"
                                                Click="OnServicePrimaryActionClicked">
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="8"
                                                        VerticalAlignment="Center">
                                                <FontIcon x:Name="ServicePrimaryActionAdminIcon"
                                                          Glyph="&#xE7EF;"
                                                          FontSize="16"
                                                          Visibility="Collapsed" />
                                                <TextBlock x:Name="ServicePrimaryActionText"
                                                           Text="Install" />
                                            </StackPanel>
                                        </Button>
                                    </StackPanel>
                                    <toolkit:SettingsExpander.Items>
                                        <toolkit:SettingsCard Header="Installed">
                                            <toolkit:SettingsCard.Description>
                                                <TextBlock Text="Whether the background service is installed on this PC."
                                                           TextWrapping="Wrap" />
                                            </toolkit:SettingsCard.Description>
                                            <StackPanel Orientation="Horizontal"
                                                        Spacing="12"
                                                        VerticalAlignment="Center">
                                                <TextBlock x:Name="ServiceInstallDetailText"
                                                           Style="{ThemeResource BodyTextBlockStyle}"
                                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                           VerticalAlignment="Center" />
                                                <Button x:Name="ServiceInstallDetailButton"
                                                        Content="Install"
                                                        Visibility="Collapsed"
                                                        Click="OnInstallShoMetricsClicked" />
                                            </StackPanel>
                                        </toolkit:SettingsCard>
                                        <toolkit:SettingsCard Header="Running Status">
                                            <toolkit:SettingsCard.Description>
                                                <TextBlock Text="Whether the background service is currently running."
                                                           TextWrapping="Wrap" />
                                            </toolkit:SettingsCard.Description>
                                            <TextBlock x:Name="ServiceRuntimeDetailText"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </toolkit:SettingsCard>
                                        <toolkit:SettingsCard Header="Connection">
                                            <toolkit:SettingsCard.Description>
                                                <TextBlock Text="Whether the panel can talk to the running background service."
                                                           TextWrapping="Wrap" />
                                            </toolkit:SettingsCard.Description>
                                            <TextBlock x:Name="ConnectionDetailText"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </toolkit:SettingsCard>
                                    </toolkit:SettingsExpander.Items>
                                </toolkit:SettingsExpander>

                            <toolkit:SettingsCard Header="PawnIO Driver">
                                <toolkit:SettingsCard.HeaderIcon>
                                    <FontIcon x:Name="PawnIoDriverStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsCard.HeaderIcon>
                                <toolkit:SettingsCard.Description>
                                    <TextBlock x:Name="PawnIoDriverDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsCard.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="PawnIoDriverText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="PawnIoInstallButton"
                                            Content="Install"
                                            Visibility="Collapsed"
                                            Click="OnInstallPawnIoClicked" />
                                </StackPanel>
                            </toolkit:SettingsCard>

                            <toolkit:SettingsCard x:Name="DiagnosticsSummaryCard"
                                                  Header="Diagnostics">
                                <toolkit:SettingsCard.HeaderIcon>
                                    <FontIcon x:Name="DiagnosticsSummaryStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsCard.HeaderIcon>
                                <toolkit:SettingsCard.Description>
                                    <TextBlock x:Name="DiagnosticsSummaryDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsCard.Description>
                                <TextBlock x:Name="WarningCountSummaryText"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </toolkit:SettingsCard>

                            <toolkit:SettingsExpander x:Name="DiagnosticsDetailsExpander"
                                                      Header="Diagnostics"
                                                      IsExpanded="False">
                                <toolkit:SettingsExpander.HeaderIcon>
                                    <FontIcon x:Name="DiagnosticsStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsExpander.HeaderIcon>
                                <toolkit:SettingsExpander.Description>
                                    <TextBlock x:Name="DiagnosticsDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsExpander.Description>
                                <TextBlock x:Name="WarningCountText"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <toolkit:SettingsExpander.Items>
                                    <toolkit:SettingsCard Header="Sensor Reads">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Last sample age and discovered metric count from the last check."
                                                       MaxWidth="320"
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <TextBlock x:Name="SensorDiagnosticsText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextAlignment="Right"
                                                   TextWrapping="Wrap" />
                                    </toolkit:SettingsCard>
                                    <toolkit:SettingsCard x:Name="WarningDiagnosticsCard"
                                                          Header="Warnings">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Helper warnings collected from health, descriptor, and snapshot reads."
                                                       MaxWidth="320"
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <TextBlock x:Name="WarningDetailsText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextAlignment="Right"
                                                   TextWrapping="Wrap" />
                                    </toolkit:SettingsCard>
                                </toolkit:SettingsExpander.Items>
                            </toolkit:SettingsExpander>
                            </StackPanel>
                        </StackPanel>

                        <TextBlock x:Name="ErrorText"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AboutPage"
                              Visibility="Collapsed"
                              Padding="40,32,40,32"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">
                        <StackPanel Spacing="6">
                            <TextBlock Text="About"
                                       Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="ShoMetrics Windows Helper"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <Border Style="{StaticResource StatusCardStyle}">
                            <Grid ColumnSpacing="24" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Control Panel version" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="PanelVersionText" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Helper version" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="HelperVersionText" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Protocol" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="ProtocolText" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Service status" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="ServiceStatusText" />

                                <TextBlock Grid.Row="4" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Log folder" />
                                <TextBlock Grid.Row="4" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="LogFolderText" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem x:Name="CheckedAtItem"
                                         Content="Not checked" />
            </muxc:NavigationView.FooterMenuItems>
        </muxc:NavigationView>

        <StackPanel HorizontalAlignment="Right"
                    Grid.Row="1"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,18,40,0">
            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    MinWidth="86"
                    Click="OnRefreshClicked" />
            <Button Content="Copy diagnostics"
                    MinWidth="132"
                    Click="OnCopyDiagnosticsClicked" />
            <Button Content="Open logs"
                    MinWidth="92"
                    Click="OnOpenLogsClicked" />
        </StackPanel>
    </Grid>
</Window>
