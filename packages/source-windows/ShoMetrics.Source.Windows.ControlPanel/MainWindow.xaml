<Window x:Class="ShoMetrics.Source.Windows.ControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
        xmlns:toolkit="using:CommunityToolkit.WinUI.Controls"
        Title="ShoMetrics Helper">
    <Grid Background="{ThemeResource ControlPanelPageBackgroundBrush}">
        <muxc:NavigationView x:Name="Navigation"
                             PaneDisplayMode="Left"
                             IsPaneToggleButtonVisible="False"
                             IsPaneOpen="True"
                             Background="{ThemeResource ControlPanelPageBackgroundBrush}"
                             IsSettingsVisible="False"
                             IsBackButtonVisible="Collapsed"
                             SelectionChanged="OnNavigationSelectionChanged">
            <muxc:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
            </muxc:NavigationView.Resources>
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Status"
                                         IsSelected="True"
                                         Tag="status" />
                <muxc:NavigationViewItem Content="About"
                                         Tag="about" />
            </muxc:NavigationView.MenuItems>

            <Grid>
                <ScrollViewer x:Name="StatusPage"
                              Padding="40,32,40,32"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">
                        <StackPanel Spacing="6">
                            <TextBlock Text="ShoMetrics status"
                                       Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="Check ShoMetrics Helper, driver access, and sensor diagnostics."
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                       TextWrapping="Wrap" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <toolkit:SettingsExpander x:Name="ServiceDetailsExpander"
                                                      Header="ShoMetrics Helper"
                                                      IsExpanded="False">
                                <toolkit:SettingsExpander.HeaderIcon>
                                    <FontIcon x:Name="ServiceTileStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsExpander.HeaderIcon>
                                <toolkit:SettingsExpander.Description>
                                    <TextBlock x:Name="ServiceTileDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsExpander.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="ServiceTileStatusText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="ServiceInstallButton"
                                            Content="Install"
                                            Visibility="Collapsed"
                                            Click="OnInstallShoMetricsClicked" />
                                </StackPanel>
                                <toolkit:SettingsExpander.Items>
                                    <toolkit:SettingsCard Header="Installed">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Whether the ShoMetrics Helper Windows service is installed on this PC."
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <StackPanel Orientation="Horizontal"
                                                    Spacing="12"
                                                    VerticalAlignment="Center">
                                            <TextBlock x:Name="ServiceInstallDetailText"
                                                       Style="{ThemeResource BodyTextBlockStyle}"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Button x:Name="ServiceInstallDetailButton"
                                                    Content="Install"
                                                    Visibility="Collapsed"
                                                    Click="OnInstallShoMetricsClicked" />
                                        </StackPanel>
                                    </toolkit:SettingsCard>
                                    <toolkit:SettingsCard Header="Running Status">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Whether the helper service is currently running."
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <TextBlock x:Name="ServiceRuntimeDetailText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </toolkit:SettingsCard>
                                    <toolkit:SettingsCard Header="Connection">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Whether the panel can talk to the running helper service."
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <TextBlock x:Name="ConnectionDetailText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    </toolkit:SettingsCard>
                                </toolkit:SettingsExpander.Items>
                            </toolkit:SettingsExpander>

                            <toolkit:SettingsCard Header="PawnIO Driver">
                                <toolkit:SettingsCard.HeaderIcon>
                                    <FontIcon x:Name="PawnIoDriverStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsCard.HeaderIcon>
                                <toolkit:SettingsCard.Description>
                                    <TextBlock x:Name="PawnIoDriverDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsCard.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="PawnIoDriverText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="PawnIoInstallButton"
                                            Content="Install"
                                            Visibility="Collapsed"
                                            Click="OnInstallPawnIoClicked" />
                                </StackPanel>
                            </toolkit:SettingsCard>

                            <toolkit:SettingsCard x:Name="DiagnosticsSummaryCard"
                                                  Header="Diagnostics">
                                <toolkit:SettingsCard.HeaderIcon>
                                    <FontIcon x:Name="DiagnosticsSummaryStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsCard.HeaderIcon>
                                <toolkit:SettingsCard.Description>
                                    <TextBlock x:Name="DiagnosticsSummaryDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsCard.Description>
                                <TextBlock x:Name="WarningCountSummaryText"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                            </toolkit:SettingsCard>

                            <toolkit:SettingsExpander x:Name="DiagnosticsDetailsExpander"
                                                      Header="Diagnostics"
                                                      IsExpanded="False">
                                <toolkit:SettingsExpander.HeaderIcon>
                                    <FontIcon x:Name="DiagnosticsStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsExpander.HeaderIcon>
                                <toolkit:SettingsExpander.Description>
                                    <TextBlock x:Name="DiagnosticsDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsExpander.Description>
                                <TextBlock x:Name="WarningCountText"
                                           Style="{ThemeResource BodyTextBlockStyle}"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           VerticalAlignment="Center" />
                                <toolkit:SettingsExpander.Items>
                                    <toolkit:SettingsCard Header="Sensor Reads">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Last sample age and discovered metric count from the last check."
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <TextBlock x:Name="SensorDiagnosticsText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </toolkit:SettingsCard>
                                    <toolkit:SettingsCard Header="Warnings">
                                        <toolkit:SettingsCard.Description>
                                            <TextBlock Text="Helper warnings collected from health, descriptor, and snapshot reads."
                                                       TextWrapping="Wrap" />
                                        </toolkit:SettingsCard.Description>
                                        <TextBlock x:Name="WarningDetailsText"
                                                   Style="{ThemeResource BodyTextBlockStyle}"
                                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                                   TextWrapping="Wrap" />
                                    </toolkit:SettingsCard>
                                </toolkit:SettingsExpander.Items>
                            </toolkit:SettingsExpander>
                        </StackPanel>

                        <TextBlock x:Name="ErrorText"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AboutPage"
                              Visibility="Collapsed"
                              Padding="40,32,40,32"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">
                        <StackPanel Spacing="6">
                            <TextBlock Text="About"
                                       Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="ShoMetrics Windows Helper"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <Border Style="{StaticResource StatusCardStyle}">
                            <Grid ColumnSpacing="24" RowSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="180" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Grid.Row="0" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Helper version" />
                                <TextBlock Grid.Row="0" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="VersionText" />

                                <TextBlock Grid.Row="1" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Protocol" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="ProtocolText" />

                                <TextBlock Grid.Row="2" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Service status" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="ServiceStatusText" />

                                <TextBlock Grid.Row="3" Grid.Column="0" Style="{StaticResource DetailLabelTextStyle}" Text="Log folder" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Style="{StaticResource DetailValueTextStyle}" x:Name="LogFolderText" TextWrapping="Wrap" />
                            </Grid>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem x:Name="CheckedAtItem"
                                         Content="Not checked" />
            </muxc:NavigationView.FooterMenuItems>
        </muxc:NavigationView>

        <StackPanel HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Orientation="Horizontal"
                    Spacing="8"
                    Margin="0,18,40,0">
            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    MinWidth="86"
                    Click="OnRefreshClicked" />
            <Button Content="Copy diagnostics"
                    MinWidth="132"
                    Click="OnCopyDiagnosticsClicked" />
            <Button Content="Open logs"
                    MinWidth="92"
                    Click="OnOpenLogsClicked" />
        </StackPanel>
    </Grid>
</Window>
