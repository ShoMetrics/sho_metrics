<Window x:Class="ShoMetrics.Source.Windows.ControlPanel.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:media="using:Microsoft.UI.Xaml.Media.Imaging"
        xmlns:muxc="using:Microsoft.UI.Xaml.Controls"
        xmlns:toolkit="using:ShoMetrics.Source.Windows.ControlPanel.Controls"
        Title="ShoMetrics Helper">
    <Grid x:Name="RootGrid"
          Background="{ThemeResource ControlPanelPageBackgroundBrush}">
        <Grid.Resources>
            <ResourceDictionary>
                <ResourceDictionary.ThemeDictionaries>
                    <ResourceDictionary x:Key="Light">
                        <media:SvgImageSource x:Key="TitleBarLogoSource"
                                              UriSource="ms-appx:///Assets/sho-metrics-icon-titlebar-light.svg" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="Dark">
                        <media:SvgImageSource x:Key="TitleBarLogoSource"
                                              UriSource="ms-appx:///Assets/sho-metrics-icon.svg" />
                    </ResourceDictionary>
                    <ResourceDictionary x:Key="HighContrast">
                        <media:SvgImageSource x:Key="TitleBarLogoSource"
                                              UriSource="ms-appx:///Assets/sho-metrics-icon.svg" />
                    </ResourceDictionary>
                </ResourceDictionary.ThemeDictionaries>
            </ResourceDictionary>
        </Grid.Resources>

        <Grid.RowDefinitions>
            <RowDefinition Height="48" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid x:Name="AppTitleBar"
              Grid.Row="0"
              Background="{ThemeResource ControlPanelPageBackgroundBrush}">
            <StackPanel Orientation="Horizontal"
                        Spacing="10"
                        Margin="16,0,0,0"
                        VerticalAlignment="Center">
                <Image Source="{ThemeResource TitleBarLogoSource}"
                       Width="18"
                       Height="18"
                       VerticalAlignment="Center" />
                <TextBlock Text="ShoMetrics Helper"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"
                           FontSize="14"
                           VerticalAlignment="Center" />
            </StackPanel>
        </Grid>

        <muxc:NavigationView x:Name="Navigation"
                             Grid.Row="1"
                             PaneDisplayMode="Left"
                             CompactPaneLength="48"
                             OpenPaneLength="180"
                             IsPaneToggleButtonVisible="False"
                             IsPaneOpen="True"
                             Background="{ThemeResource ControlPanelPageBackgroundBrush}"
                             IsSettingsVisible="False"
                             IsBackButtonVisible="Collapsed"
                             SelectionChanged="OnNavigationSelectionChanged">
            <muxc:NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
                <SolidColorBrush x:Key="NavigationViewContentGridBorderBrush" Color="Transparent" />
                <Thickness x:Key="NavigationViewContentGridBorderThickness">0</Thickness>
                <CornerRadius x:Key="NavigationViewContentGridCornerRadius">0</CornerRadius>
            </muxc:NavigationView.Resources>
            <muxc:NavigationView.MenuItems>
                <muxc:NavigationViewItem Content="Status"
                                         IsSelected="True"
                                         Icon="Home"
                                         Tag="status" />
                <muxc:NavigationViewItem Content="About"
                                         Icon="Help"
                                         Tag="about" />
            </muxc:NavigationView.MenuItems>

            <Grid>
                <ScrollViewer x:Name="StatusPage"
                              Padding="40,32,40,32"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="StatusContentPanel"
                                Spacing="24">
                        <Grid x:Name="StatusHeaderGrid"
                              ColumnSpacing="24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <StackPanel x:Name="StatusHeaderText"
                                        Spacing="6">
                                <TextBlock Text="ShoMetrics status"
                                           Style="{ThemeResource TitleTextBlockStyle}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="Check ShoMetrics Helper, driver access, and sensor diagnostics."
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           TextWrapping="Wrap" />
                            </StackPanel>
                            <Grid x:Name="StatusHeaderActions"
                                  Grid.Column="1"
                                  Margin="24,0,0,0"
                                  HorizontalAlignment="Right"
                                  VerticalAlignment="Top">
                                <StackPanel x:Name="ActionButtonsPanel"
                                            Orientation="Horizontal"
                                            Spacing="8">
                                    <Button x:Name="RefreshButton"
                                            Content="Refresh"
                                            MinWidth="86"
                                            Click="OnRefreshClicked" />
                                    <Button x:Name="CopyDiagnosticsButton"
                                            Content="Copy diagnostics"
                                            MinWidth="132"
                                            Click="OnCopyDiagnosticsClicked" />
                                    <Button x:Name="OpenLogsButton"
                                            Content="Open logs"
                                            MinWidth="92"
                                            Click="OnOpenLogsClicked" />
                                </StackPanel>
                            </Grid>
                        </Grid>

                        <StackPanel Spacing="4">
                            <toolkit:SettingsExpander x:Name="ServiceDetailsExpander"
                                                      Header="ShoMetrics Helper"
                                                      IsExpanded="False">
                                <toolkit:SettingsExpander.HeaderIcon>
                                    <FontIcon x:Name="ServiceTileStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsExpander.HeaderIcon>
                                <toolkit:SettingsExpander.Description>
                                    <TextBlock x:Name="ServiceTileDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsExpander.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="ServiceTileStatusLabel"
                                               Text="Status:"
                                               Visibility="Collapsed"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="ServiceTileStatusText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="ServiceInstallButton"
                                            Content="Install"
                                            Visibility="Collapsed"
                                            Click="OnInstallShoMetricsClicked" />
                                </StackPanel>
                                <toolkit:SettingsExpander.Items>
                                    <toolkit:ResponsiveDetailRow x:Name="ServiceInstalledRow"
                                                                 Header="Installed"
                                                                 Description="Whether the ShoMetrics Helper Windows service is installed on this PC."
                                                                 ActionText="Install"
                                                                 ActionClick="OnInstallShoMetricsClicked" />
                                    <toolkit:ResponsiveDetailRow x:Name="ServiceRunningRow"
                                                                 Header="Running Status"
                                                                 Description="Whether the helper service is currently running." />
                                    <toolkit:ResponsiveDetailRow x:Name="ServiceConnectionRow"
                                                                 Header="Connection"
                                                                 Description="Whether the panel can talk to the running helper service." />
                                </toolkit:SettingsExpander.Items>
                            </toolkit:SettingsExpander>

                            <toolkit:SettingsCard x:Name="PawnIoDriverCard"
                                                  Header="PawnIO Driver">
                                <toolkit:SettingsCard.HeaderIcon>
                                    <FontIcon x:Name="PawnIoDriverStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsCard.HeaderIcon>
                                <toolkit:SettingsCard.Description>
                                    <TextBlock x:Name="PawnIoDriverDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsCard.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="12"
                                            VerticalAlignment="Center">
                                    <TextBlock x:Name="PawnIoDriverLabel"
                                               Text="Status:"
                                               Visibility="Collapsed"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <TextBlock x:Name="PawnIoDriverText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                    <Button x:Name="PawnIoInstallButton"
                                            Content="Install"
                                            Visibility="Collapsed"
                                            Click="OnInstallPawnIoClicked" />
                                </StackPanel>
                            </toolkit:SettingsCard>

                            <toolkit:SettingsCard x:Name="DiagnosticsSummaryCard"
                                                  Header="Diagnostics">
                                <toolkit:SettingsCard.HeaderIcon>
                                    <FontIcon x:Name="DiagnosticsSummaryStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsCard.HeaderIcon>
                                <toolkit:SettingsCard.Description>
                                    <TextBlock x:Name="DiagnosticsSummaryDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsCard.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4">
                                    <TextBlock x:Name="DiagnosticsSummaryLabel"
                                               Text="Status:"
                                               Visibility="Collapsed"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="WarningCountSummaryText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                            </toolkit:SettingsCard>

                            <toolkit:SettingsExpander x:Name="DiagnosticsDetailsExpander"
                                                      Header="Diagnostics"
                                                      IsExpanded="False">
                                <toolkit:SettingsExpander.HeaderIcon>
                                    <FontIcon x:Name="DiagnosticsStatusIcon"
                                              AutomationProperties.AccessibilityView="Raw"
                                              FontSize="18" />
                                </toolkit:SettingsExpander.HeaderIcon>
                                <toolkit:SettingsExpander.Description>
                                    <TextBlock x:Name="DiagnosticsDetailText"
                                               TextWrapping="Wrap" />
                                </toolkit:SettingsExpander.Description>
                                <StackPanel Orientation="Horizontal"
                                            Spacing="4">
                                    <TextBlock x:Name="WarningCountLabel"
                                               Text="Status:"
                                               Visibility="Collapsed"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                    <TextBlock x:Name="WarningCountText"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                               VerticalAlignment="Center" />
                                </StackPanel>
                                <toolkit:SettingsExpander.Items>
                                    <toolkit:ResponsiveDetailRow x:Name="SensorDiagnosticsRow"
                                                                 Header="Sensor Reads"
                                                                 Description="Last sample age and discovered metric count from the last check."
                                                                 ValueLabel="Details:" />
                                    <toolkit:ResponsiveDetailRow x:Name="WarningDiagnosticsRow"
                                                                 Header="Warnings"
                                                                 Description="Helper warnings collected from health, descriptor, and snapshot reads."
                                                                 ValueLabel="Details:" />
                                </toolkit:SettingsExpander.Items>
                            </toolkit:SettingsExpander>
                        </StackPanel>

                        <TextBlock x:Name="ErrorText"
                                   Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer x:Name="AboutPage"
                              Visibility="Collapsed"
                              Padding="40,32,40,32"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="24">
                        <StackPanel Spacing="6">
                            <TextBlock Text="About"
                                       Style="{ThemeResource TitleTextBlockStyle}" />
                            <TextBlock Text="ShoMetrics Windows Helper"
                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                        </StackPanel>

                        <StackPanel Spacing="4">
                            <toolkit:SettingsCard x:Name="AboutPanelVersionCard"
                                                  Header="Control Panel version">
                                <TextBlock x:Name="PanelVersionText"
                                           Style="{StaticResource DetailValueTextStyle}"
                                           TextAlignment="Right" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard x:Name="AboutHelperVersionCard"
                                                  Header="Helper version">
                                <TextBlock x:Name="HelperVersionText"
                                           Style="{StaticResource DetailValueTextStyle}"
                                           TextAlignment="Right" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard x:Name="AboutProtocolCard"
                                                  Header="Protocol">
                                <TextBlock x:Name="ProtocolText"
                                           Style="{StaticResource DetailValueTextStyle}"
                                           TextAlignment="Right" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard x:Name="AboutServiceStatusCard"
                                                  Header="Service status">
                                <TextBlock x:Name="ServiceStatusText"
                                           Style="{StaticResource DetailValueTextStyle}"
                                           TextAlignment="Right" />
                            </toolkit:SettingsCard>
                            <toolkit:SettingsCard x:Name="AboutLogFolderCard"
                                                  Header="Log folder">
                                <TextBlock x:Name="LogFolderText"
                                           Style="{StaticResource DetailValueTextStyle}"
                                           TextAlignment="Right"
                                           TextWrapping="Wrap" />
                            </toolkit:SettingsCard>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <muxc:NavigationView.FooterMenuItems>
                <muxc:NavigationViewItem x:Name="CheckedAtItem"
                                         Content="Not checked" />
            </muxc:NavigationView.FooterMenuItems>
        </muxc:NavigationView>

    </Grid>
</Window>
