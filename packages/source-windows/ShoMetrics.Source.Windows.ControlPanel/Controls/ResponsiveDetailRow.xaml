<UserControl x:Class="ShoMetrics.Source.Windows.ControlPanel.Controls.ResponsiveDetailRow"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="52">
    <Border Background="{ThemeResource SettingsCardBackground}"
            BorderBrush="{ThemeResource SettingsCardBorderBrush}"
            BorderThickness="{ThemeResource SettingsExpanderItemBorderThickness}"
            Padding="{ThemeResource SettingsExpanderItemPadding}">
        <Grid VerticalAlignment="Center">
            <Grid x:Name="WideLayout"
                  ColumnSpacing="24"
                  VerticalAlignment="Center">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding Header, ElementName=Root}"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Description, ElementName=Root}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            Spacing="12"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                    <TextBlock x:Name="WideValueText"
                               Text="{Binding Value, ElementName=Root}"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextAlignment="Right"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <Button Content="{Binding ActionText, ElementName=Root}"
                            Visibility="{Binding ActionVisibility, ElementName=Root}"
                            Click="OnActionButtonClick" />
                </StackPanel>
            </Grid>

            <StackPanel x:Name="NarrowLayout"
                        Spacing="10"
                        Visibility="Collapsed">
                <StackPanel>
                    <TextBlock Text="{Binding Header, ElementName=Root}"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding Description, ElementName=Root}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <StackPanel Orientation="Horizontal"
                            Spacing="8"
                            VerticalAlignment="Center">
                    <TextBlock Text="{Binding ValueLabel, ElementName=Root}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               VerticalAlignment="Center" />
                    <TextBlock Text="{Binding Value, ElementName=Root}"
                               Style="{ThemeResource BodyTextBlockStyle}"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"
                               VerticalAlignment="Center" />
                    <Button Content="{Binding ActionText, ElementName=Root}"
                            Visibility="{Binding ActionVisibility, ElementName=Root}"
                            Click="OnActionButtonClick" />
                </StackPanel>
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
