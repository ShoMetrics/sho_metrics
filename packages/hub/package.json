{
    "scripts": {
        "prebuild": "npm run generate:proto",
        "build": "rollup -c",
        "test": "npm run test:unit",
        "pretest:unit": "npm run generate:proto",
        "test:unit": "node scripts/clean-test-output.mjs && tsc -p tsconfig.test.json && node scripts/write-test-package.mjs && node --test --test-isolation=none .test-dist/src/**/*.test.js",
        "test:visual": "playwright test -c playwright.visual.config.ts",
        "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
        "perf:monitor": "node scripts/diagnostics/runtime-performance-monitor.mjs",
        "diagnostics:runtime": "node scripts/diagnostics/runtime-performance-monitor.mjs",
        "diagnostics:source": "node scripts/diagnostics/metric-source-comparison.mjs",
        "benchmark:protobuf": "node scripts/run-buf.mjs generate --template scripts/benchmark/protobuf/buf.gen.yaml && node scripts/benchmark/protobuf/protobuf-performance-benchmark.mjs",
        "benchmark:resvg": "node scripts/benchmark/resvg-minimal.mjs",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.ez.sho-metrics\"",
        "prelint": "npm run generate:proto",
        "lint": "eslint .",
        "prelint:fix": "npm run generate:proto",
        "lint:fix": "eslint . --fix",
        "proto:format": "node scripts/run-buf.mjs format ../../contracts/proto -w",
        "proto:lint": "node scripts/run-buf.mjs lint ../../contracts/proto",
        "proto:build": "node scripts/run-buf.mjs build ../../contracts/proto",
        "proto:dep:update": "node scripts/run-buf.mjs dep update ../../contracts/proto",
        "generate:proto": "node scripts/run-buf.mjs generate ../../contracts/proto --template scripts/proto/buf.gen.yaml"
    },
    "type": "module",
    "devDependencies": {
        "@bufbuild/buf": "^1.69.0",
        "@bufbuild/protoc-gen-es": "^2.12.0",
        "@elgato/cli": "^1.7.4",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.1.0",
        "@tsconfig/node20": "^20.1.2",
        "@types/node": "~24.1.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "eslint": "^9.39.4",
        "globals": "^17.5.0",
        "rollup": "^4.0.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.59.0"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.12.0",
        "@bufbuild/protovalidate": "^1.2.0",
        "@elgato/streamdeck": "^2.0.0",
        "@resvg/resvg-js": "^2.6.2",
        "@types/d3-shape": "^3.1.8",
        "d3-shape": "^3.2.0",
        "fast-equals": "^6.0.0",
        "lru-cache": "^11.3.6",
        "lucide": "^1.11.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "systeminformation": "^5.31.5"
    }
}
