{
    "scripts": {
        "brand:sync": "npm --prefix ../assets/brand run sync",
        "brand:verify": "npm --prefix ../assets/brand run verify",
        "prebuild": "npm run generate:proto",
        "build": "rollup -c --environment SHO_METRICS_BUILD_MODE:production",
        "prebuild:dev": "npm run generate:proto",
        "build:dev": "rollup -c --environment SHO_METRICS_BUILD_MODE:development",
        "test": "npm run test:unit",
        "pretest:unit": "npm run generate:proto",
        "test:unit": "node scripts/clean-test-output.mjs && tsc -p tsconfig.test.json && node scripts/write-test-package.mjs && node --test --test-isolation=none .test-dist/src/**/*.test.js",
        "pretest:pi": "npm run generate:proto",
        "test:pi": "node scripts/clean-test-output.mjs && tsc -p tsconfig.pi-test.json && node scripts/write-test-package.mjs && node --test --test-isolation=none --require ./.test-dist/src/property-inspector/testing/dom-test-setup.js .test-dist/src/property-inspector/**/*.pi.test.js",
        "pretest:unit:coverage": "npm run generate:proto",
        "test:unit:coverage": "node scripts/clean-test-output.mjs && tsc -p tsconfig.test.json --sourceMap true --inlineSources true && node scripts/write-test-package.mjs && c8 --config .c8rc.json node --test --test-isolation=none .test-dist/src/**/*.test.js",
        "test:visual": "playwright test -c playwright.visual.config.ts",
        "test:visual:update": "playwright test -c playwright.visual.config.ts --update-snapshots",
        "perf:monitor": "node scripts/diagnostics/runtime-performance-monitor.mjs",
        "diagnostics:runtime": "node scripts/diagnostics/runtime-performance-monitor.mjs",
        "diagnostics:source": "node scripts/diagnostics/metric-source-comparison.mjs",
        "diagnostics:windows-helper-lhm-parity": "node scripts/diagnostics/windows-helper-lhm-parity.mjs",
        "benchmark:protobuf": "node scripts/run-buf.mjs generate --template scripts/benchmark/protobuf/buf.gen.yaml && node scripts/benchmark/protobuf/protobuf-performance-benchmark.mjs",
        "benchmark:resvg": "node scripts/benchmark/resvg-minimal.mjs",
        "i18n:generate": "node scripts/i18n-generate.mjs",
        "i18n:check": "node scripts/i18n-check.mjs",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.ez.sho-metrics\"",
        "prelint": "npm run generate:proto",
        "lint": "eslint .",
        "prelint:fix": "npm run generate:proto",
        "lint:fix": "eslint . --fix",
        "proto:format": "node scripts/run-buf.mjs format ../../contracts/proto -w",
        "proto:lint": "node scripts/run-buf.mjs lint ../../contracts/proto",
        "proto:build": "node scripts/run-buf.mjs build ../../contracts/proto",
        "proto:dep:update": "node scripts/run-buf.mjs dep update ../../contracts/proto",
        "generate:proto": "node scripts/run-buf.mjs generate ../../contracts/proto --template scripts/proto/buf.gen.yaml"
    },
    "type": "module",
    "devDependencies": {
        "@bufbuild/buf": "^1.69.0",
        "@bufbuild/protoc-gen-es": "^2.12.0",
        "@elgato/cli": "^1.7.4",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.1.0",
        "@testing-library/react": "^16.3.2",
        "@testing-library/user-event": "^14.6.1",
        "@tsconfig/node20": "^20.1.2",
        "@types/jsdom": "^28.0.3",
        "@types/node": "~24.1.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@types/validator": "13.15.10",
        "c8": "^11.0.0",
        "eslint": "^9.39.4",
        "globals": "^17.5.0",
        "jsdom": "^29.1.1",
        "jsonata": "2.0.6",
        "rollup": "^4.0.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.59.0"
    },
    "dependencies": {
        "@bufbuild/protobuf": "^2.12.0",
        "@bufbuild/protovalidate": "^1.2.0",
        "@elgato/streamdeck": "^2.0.0",
        "@grpc/grpc-js": "^1.14.0",
        "@resvg/resvg-js": "^2.6.2",
        "@types/d3-shape": "^3.1.8",
        "d3-shape": "^3.2.0",
        "fast-equals": "^6.0.0",
        "jq-wasm": "1.1.0-jq-1.8.1",
        "lru-cache": "^11.3.6",
        "lucide": "^1.11.0",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "systeminformation": "^5.31.5",
        "validator": "13.15.35",
        "workerpool": "10.0.2"
    }
}
