{
    "scripts": {
        "build": "rollup -c",
        "test": "npm run test:unit",
        "test:unit": "node scripts/clean-test-output.mjs && tsc -p tsconfig.test.json && node scripts/write-test-package.mjs && node --test --test-isolation=none .test-dist/src/**/*.test.js",
        "watch": "rollup -c -w --watch.onEnd=\"streamdeck restart com.ez.sho-metrics\"",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "generate:proto": "pbjs -t static-module -w es6 -o src/generated/snapshot.js ../../contracts/proto/shometrics/v1/snapshot.proto && pbts -o src/generated/snapshot.d.ts src/generated/snapshot.js"
    },
    "type": "module",
    "devDependencies": {
        "@elgato/cli": "^1.7.4",
        "@eslint/js": "^9.39.4",
        "@rollup/plugin-commonjs": "^29.0.2",
        "@rollup/plugin-json": "^6.1.0",
        "@rollup/plugin-node-resolve": "^15.2.2",
        "@rollup/plugin-terser": "^1.0.0",
        "@rollup/plugin-typescript": "^12.1.0",
        "@tsconfig/node20": "^20.1.2",
        "@types/node": "~24.1.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "eslint": "^9.39.4",
        "globals": "^17.5.0",
        "protobufjs-cli": "^2.0.1",
        "rollup": "^4.0.2",
        "tslib": "^2.6.2",
        "typescript": "^5.2.2",
        "typescript-eslint": "^8.59.0"
    },
    "dependencies": {
        "@elgato/streamdeck": "^2.0.0",
        "@resvg/resvg-js": "^2.6.2",
        "@types/d3-shape": "^3.1.8",
        "d3-shape": "^3.2.0",
        "lucide": "^1.11.0",
        "protobufjs": "^8.0.1",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "systeminformation": "^5.31.5"
    }
}
