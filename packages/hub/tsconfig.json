{
	"extends": "@tsconfig/node20/tsconfig.json",
	"compilerOptions": {
		"customConditions": [
			"node"
		],
		"jsx": "react-jsx",
		"lib": [
			"ES2022",
			"DOM"
		],
		"module": "ES2022",
		"moduleResolution": "Bundler",
		"noImplicitOverride": true
	},
	"include": [
		"src/**/*.ts",
		"src/**/*.tsx"
	],
	"exclude": [
		"node_modules"
	]
}
