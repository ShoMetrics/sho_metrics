{
    "extends": "@tsconfig/node20/tsconfig.json",
    "compilerOptions": {
        "lib": [
            "ES2022",
            "DOM"
        ],
        "module": "CommonJS",
        "moduleResolution": "Node",
        "jsx": "react-jsx",
        "noImplicitOverride": true,
        "outDir": ".test-dist",
        "rootDir": ".",
        "sourceMap": false,
        "types": [
            "node"
        ]
    },
    "include": [
        "src/env.d.ts",
        "src/**/*.test.ts"
    ],
    "exclude": [
        "node_modules",
        "src/property-inspector/**/*.tsx"
    ]
}
